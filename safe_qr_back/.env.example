PORT=3000
NODE_ENV=development
LOG_LEVEL=info
MAX_RAW_CONTENT_BYTES=8192

# Opcional: consulta Firestore `suspicious_hosts/clones` (campo `urls`) para clones/phishing.
# Use UMA das formas (conta de serviço com role Cloud Datastore User / Firebase Admin SDK).
# GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\absoluto\safe-qr-app-xxxxx.json
# ou, na pasta deste back (ficheiros safe-qr-app-*.json estão no .gitignore):
# GOOGLE_APPLICATION_CREDENTIALS=./safe-qr-app-xxxx.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIRESTORE_SUSPICIOUS_CACHE_MS=60000

# Pub/Sub (produtor — credencial separada do Firestore)
# GCP_PROJECT_ID=safe-qr-app
# PUBSUB_ENABLED=true
# PUBSUB_TOPIC=safe-qr-analyze-events
# PUBSUB_GOOGLE_APPLICATION_CREDENTIALS=./credentials/safe-qr-pubsub-publisher.json

# Painel admin (safe_qr_web) — header X-Admin-Key
# ADMIN_API_KEY=troque-por-uma-chave-segura-com-16-chars
# SCAN_EVENTS_COLLECTION=scan_events

# Google Safe Browsing API v4 (reputação global de URLs)
# Crie a chave em: https://console.cloud.google.com/apis/credentials (API: Safe Browsing API)
# SAFE_BROWSING_ENABLED=true
# GOOGLE_SAFE_BROWSING_API_KEY=sua-chave-google-cloud
# SAFE_BROWSING_CACHE_MS=300000
