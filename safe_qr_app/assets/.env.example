# Base do backend (sem barra no fim). Android: NUNCA use 127.0.0.1 para alcançar o PC.
# Erro comum: celular físico com 10.0.2.2 — esse host só existe no emulador.
# - Android Emulator → http://10.0.2.2:3000
# - Celular físico (mesma Wi‑Fi) → http://<IP-do-PC>:3000 (veja o log do servidor ao subir)
# - Web / desktop / iOS Simulator → http://127.0.0.1:3000
API_BASE_URL=http://10.0.2.2:3000

# local = heurística no aparelho | remote = POST /v1/qr/analyze
ANALYZE_MODE=remote
API_CONNECT_TIMEOUT_MS=20000
API_RECEIVE_TIMEOUT_MS=20000
THEME_PERSISTENCE_KEY=safe_qr_theme_mode
