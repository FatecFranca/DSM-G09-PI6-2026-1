# GCP
GCP_PROJECT_ID=safe-qr-app-xxxxx
GOOGLE_APPLICATION_CREDENTIALS=./credentials/safe-qr-pubsub-consumer.json

# Pub/Sub — fan-out (mesmo tópico, duas subscriptions)
PUBSUB_SUBSCRIPTION=safe-qr-analyze-events-sub
PUBSUB_SUBSCRIPTION_AUDIT=safe-qr-analyze-events-sub
PUBSUB_SUBSCRIPTION_HISTORY=safe-qr-analyze-events-sub-history
CONSUMER_ENABLED=true
CONSUMER_MAX_MESSAGES=10
CONSUMER_ACK_DEADLINE_SEC=60

# Firestore
FIRESTORE_ENABLED=true
FIRESTORE_COLLECTION=scan_events
FIRESTORE_HISTORY_COLLECTION=history
FIRESTORE_HISTORY_ITEMS_SUBCOLLECTION=items
FIREBASE_GOOGLE_APPLICATION_CREDENTIALS=../safe_qr_back/safe-qr-app-dbc39536954e.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Runtime
NODE_ENV=development
LOG_LEVEL=info
